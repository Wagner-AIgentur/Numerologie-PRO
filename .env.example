# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (Email)
RESEND_API_KEY=re_...

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=123456789

# ElevenLabs Voice Agent
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
ELEVENLABS_WEBHOOK_SECRET=your-elevenlabs-webhook-secret

# Cal.com
CALCOM_API_KEY=your-calcom-api-key
CALCOM_EVENT_TYPE_ID=your-calcom-event-type-id
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# Cron Jobs
CRON_SECRET=your-cron-secret

# Meta / Instagram
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-verify-token
META_ACCESS_TOKEN=your-access-token
META_PIXEL_ID=your-pixel-id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-account-id

# Upstash Redis (Rate Limiting)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# WhatsApp (optional)
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_ACCESS_TOKEN=your-wa-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
