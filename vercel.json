      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/stripe/webhook/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/session-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sequence-processor",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/auto-tagger",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/lead-scoring",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/broadcast-sender",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/purge-deleted-accounts",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/competitor-scrape",
      "schedule": "0 1 * * *"
